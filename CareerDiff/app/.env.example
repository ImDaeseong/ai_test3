# Copy this file to .env.local and fill in your own key to enable real
# LLM analysis. Leave OPENAI_API_KEY unset (or delete .env.local) to run
# on the built-in mock analysis result instead — no key is required for
# local development. See src/core/analysis/AnalysisOrchestrator.ts.

OPENAI_API_KEY=

# Optional. Defaults to gpt-4o-mini if unset.
OPENAI_MODEL=
